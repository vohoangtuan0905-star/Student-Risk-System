{
  "deployed_model_name": "LogisticRegression",
  "feature_columns": [
    "gender",
    "age_at_enrollment",
    "gpa",
    "tuition_debt",
    "scholarship",
    "failed_subjects",
    "credits_enrolled",
    "credits_passed",
    "warning_level"
  ],
  "output_schema": {
    "prediction": "0 hoặc 1",
    "dropout_probability": "xác suất bỏ học từ 0 đến 1",
    "risk_level": "Safe / Warning / Danger"
  },
  "risk_rule": {
    "Danger": "probability >= 0.70",
    "Warning": "0.40 <= probability < 0.70",
    "Safe": "probability < 0.40"
  }
}